# Template pour secrets Streamlit. À copier en .streamlit/secrets.toml (gitignored)
# et adapter localement. En prod (Streamlit Cloud), définir dans le dashboard
# "Settings -> Secrets" en TOML format. Aucune de ces valeurs n'est visible
# côté utilisateur ni dans le repo.

# Mot de passe partagé pour accéder à l'app (donné aux membres du Discord).
password = "change-moi"

# PIN admin pour révéler le compteur de visites (clic sur le logo 📊).
admin_pin = "0000"

# SMTP Gmail pour envoyer les feedbacks utilisateurs vers ta boîte.
# smtp_user     : ton adresse Gmail expéditrice
# smtp_password : App Password Gmail (https://myaccount.google.com/apppasswords)
# smtp_to       : adresse destinataire (la tienne)
smtp_user = "ton.email@gmail.com"
smtp_password = "xxxx xxxx xxxx xxxx"
smtp_to = "ton.email@gmail.com"

# Compteurs counterapi.dev (gratuit, anonyme). Choisis des noms uniques et obscurs.
# counter_visit : incrémenté à chaque ouverture de l'app (1x par session)
# counter_usage : incrémenté à chaque clic "Analyser" réussi
counter_visit = "wheel-roll-visit-CHANGE-MOI"
counter_usage = "wheel-roll-usage-CHANGE-MOI"

# Token URL pour t'exclure des compteurs.
# Accède à l'app avec https://...streamlit.app/?admin=TON_TOKEN_ICI
# → tes visites et tes clics Analyser ne sont PAS comptés
# → les stats apparaissent automatiquement en bas (sans clic logo)
admin_url_token = "change-moi-token-aleatoire"
